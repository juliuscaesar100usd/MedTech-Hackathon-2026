# Copy to backend/.env (or export) to override defaults.

# --- Database ---
# Local zero-config default is SQLite. For production use PostgreSQL:
# DATABASE_URL=postgresql+psycopg2://medarchive:medarchive@db:5432/medarchive
DATABASE_URL=sqlite:///./medarchive.db

# --- Matching thresholds ---
MATCH_AUTO_THRESHOLD=0.85
MATCH_REVIEW_THRESHOLD=0.60
USE_EMBEDDINGS=false
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2

# --- OCR ---
OCR_LANGS=rus+kaz+eng
OCR_DPI=300

# --- Validation ---
PRICE_ANOMALY_PCT=0.50
DEFAULT_CURRENCY=KZT

# --- API ---
CORS_ORIGINS=["*"]

# --- AI assistant (chatbot) ---
# The assistant turns free-text preferences ("blood test in Almaty under 5000 ₸")
# into filtered catalog results. It works OFFLINE with a deterministic rule-based
# parser. Optionally set an Anthropic API key to enable the Claude tier for
# messier / conversational phrasing — it degrades gracefully to the rule-based
# parser whenever the key or the `anthropic` SDK is missing.
ASSISTANT_ENABLED=true
# ANTHROPIC_API_KEY=sk-ant-...
ASSISTANT_MODEL=claude-opus-4-8
ASSISTANT_MAX_RESULTS=5
