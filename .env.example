# Copy to backend/.env (or export) to override defaults.

# --- Database ---
# Local zero-config default is SQLite. For production use PostgreSQL:
# DATABASE_URL=postgresql+psycopg2://medarchive:medarchive@db:5432/medarchive
DATABASE_URL=sqlite:///./medarchive.db

# --- Matching thresholds ---
MATCH_AUTO_THRESHOLD=0.85
MATCH_REVIEW_THRESHOLD=0.60
USE_EMBEDDINGS=false
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2

# --- OCR ---
OCR_LANGS=rus+kaz+eng
OCR_DPI=300

# --- Validation ---
PRICE_ANOMALY_PCT=0.50
DEFAULT_CURRENCY=KZT

# --- API ---
CORS_ORIGINS=["*"]
