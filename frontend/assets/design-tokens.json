{
  "$schema": "https://design-tokens.org/schema.json",
  "brand": "MedArchive",
  "version": "1.0.0",
  "description": "Portable export of the live tokens in frontend/src/styles.css (:root). Source of truth: docs/brand-guidelines.md.",
  "color": {
    "brand": {
      "primary":     { "value": "#0e7490", "note": "teal-700 — primary brand, CTAs, links, accent" },
      "primary-600": { "value": "#0891b2", "note": "cyan-600 — gradient light end, fills/borders (non-text)" },
      "primary-700": { "value": "#0e7490" },
      "primary-800": { "value": "#155e75", "note": "active/pressed, dark gradient stop" },
      "primary-50":  { "value": "#ecfeff" },
      "primary-100": { "value": "#cffafe" },
      "accent":      { "value": "#0e7490", "note": "locked to primary hue — AA on white (5.36:1)" },
      "accent-50":   { "value": "#ecfeff" }
    },
    "neutral": {
      "bg":            { "value": "#f4f7fb" },
      "surface":       { "value": "#ffffff" },
      "surface-2":     { "value": "#f8fafc" },
      "border":        { "value": "#e2e8f0" },
      "border-strong": { "value": "#cbd5e1" },
      "text":          { "value": "#0f172a" },
      "text-muted":    { "value": "#64748b" },
      "text-faint":    { "value": "#94a3b8" }
    },
    "semantic": {
      "success":    { "value": "#059669", "bg": "#ecfdf5" },
      "warning":    { "value": "#b45309", "bg": "#fffbeb" },
      "danger":     { "value": "#dc2626", "bg": "#fef2f2" },
      "info":       { "value": "#0369a1", "bg": "#f0f9ff", "note": "the only sanctioned blue" }
    }
  },
  "typography": {
    "font-display": { "value": "'Manrope', 'Inter', system-ui, sans-serif", "note": "headings, wordmark, metrics" },
    "font-sans":    { "value": "'Inter', system-ui, sans-serif", "note": "body, UI, data" },
    "font-mono":    { "value": "ui-monospace, SFMono-Regular, Menlo, monospace" },
    "scale": {
      "hero-h1": { "size": "clamp(30px,4.4vw,46px)", "weight": 800, "line": 1.05 },
      "h1":      { "size": "28px", "weight": 700, "line": 1.2 },
      "h2":      { "size": "clamp(24px,3.4vw,34px)", "weight": 700, "line": 1.15 },
      "h3":      { "size": "17px", "weight": 700, "line": 1.3 },
      "metric":  { "size": "clamp(28px,3.4vw,38px)", "weight": 800, "line": 1.0 },
      "body":    { "size": "15px", "weight": 400, "line": 1.55 },
      "small":   { "size": "14px", "weight": 600, "line": 1.4 },
      "caption": { "size": "12px", "weight": 600, "line": 1.4 }
    }
  },
  "space": { "1": "4px", "2": "8px", "3": "12px", "4": "16px", "5": "24px", "6": "32px", "7": "48px", "8": "64px" },
  "radius": { "sm": "6px", "md": "10px", "lg": "14px", "xl": "20px", "pill": "999px" },
  "shadow": {
    "sm": "0 1px 2px rgba(15,23,42,0.06), 0 1px 3px rgba(15,23,42,0.05)",
    "md": "0 4px 12px rgba(15,23,42,0.08)",
    "lg": "0 12px 32px rgba(15,23,42,0.12)"
  }
}
